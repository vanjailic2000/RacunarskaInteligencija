"""
1. BAR CHART — px.bar()
   KADA: porediš kategorije i njihove količine.
   PRIMER: broj filmova po žanru, broj filmova po režiseru.

   ŠABLON:
       fig = px.bar(x=brojanje.index, y=brojanje.values)
       fig.show()

2. HISTOGRAM — px.histogram()
   KADA: prikazuješ raspodelu jedne numeričke kolone.
   PRIMER: godine filmova, BPM, ocene, trajanje.

   ŠABLON:
       fig = px.histogram(df, x="BROJČANA_KOLONA")
       fig.show()

3. SCATTER PLOT — px.scatter()
   KADA: prikazuješ vezu između dve promenljive.
   PRIMER: godina i žanr, danceability i energy.

   ŠABLON:
       fig = px.scatter(df, x="KOLONA_X", y="KOLONA_Y")
       fig.show()

4. PIE CHART — px.pie()
   KADA: prikazuješ udele/procente delova u celini.

   ŠABLON:
       brojanje = df["KATEGORIJA"].value_counts()
       fig = px.pie(values=brojanje.values, names=brojanje.index)
       fig.show()

5. LINE CHART — px.line()
   KADA: pratiš promenu kroz vreme ili uređeni niz.

   ŠABLON:
       grupisano = df.groupby("GODINA")["VREDNOST"].sum().reset_index()
       fig = px.line(grupisano, x="GODINA", y="VREDNOST")
       fig.show()

6. BOX PLOT — px.box()
   KADA: porediš raspodelu numeričke vrednosti između kategorija.

   ŠABLON:
       fig = px.box(df, x="KATEGORIJA", y="BROJČANA_KOLONA")
       fig.show()

7. HEATMAP — px.imshow()
   KADA: prikazuješ korelacije numeričkih kolona.

   ŠABLON:
       korelacija = df.select_dtypes(include="number").corr()
       fig = px.imshow(korelacija, text_auto=True)
       fig.show()

8. 3D SCATTER — px.scatter_3d()
   KADA: prikazuješ odnos tri numeričke promenljive.

   ŠABLON:
       fig = px.scatter_3d(df, x="KOLONA_X", y="KOLONA_Y", z="KOLONA_Z")
       fig.show()
"""


# ============================================================
# BRZI REČNIK: TEKST ZADATKA -> KOMANDA
# ============================================================

"""
učitati CSV                         -> pd.read_csv()
prvih 5/10 redova                   -> head() / head(10)
nazivi kolona                       -> columns
prazne ćelije                       -> isnull().sum()
tipovi podataka                     -> dtypes
pronaći tekst/ime                   -> str.contains()
sortirati                           -> sort_values()
prebrojati                          -> value_counts()
grupisati                           -> groupby()
prosek                              -> mean()
zbir                                -> sum()
najmanja vrednost                   -> min()
najveća vrednost                    -> max()
prvih 10                            -> head(10)
poslednjih 10                       -> tail(10)
više vrednosti u jednoj ćeliji      -> str.split() + explode()
samo nazivi                         -> ["title"]
ceo pronađeni red                   -> df[uslov]
obrnuto sortiranje                  -> ascending=False
"""

print("\nPodsetnik je učitan. Grafikoni su zakomentarisani.")
print("Ukloni # ispred fig.show() kada želiš prikaz grafikona.")
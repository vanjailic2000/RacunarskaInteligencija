# ============================================================
# ZADATAK 4 — VARIJANTA 1A
# Sortirati filmove po primarnom žanru.
# ============================================================

# Šta se radi:
# split(",") deli više žanrova po zarezu, str[0] uzima prvi,
# a strip() uklanja višak razmaka.

filmovi_sa_primarnim_zanrom = df.copy()
filmovi_sa_primarnim_zanrom["primary_genre"] = (
    filmovi_sa_primarnim_zanrom["genres"]
    .str.split(",")
    .str[0]
    .str.strip()
)

# print(filmovi_sa_primarnim_zanrom.sort_values("primary_genre")[["title", "primary_genre"]])


# ============================================================
# ZADATAK 5 — VARIJANTA 1B
# Izračunati koliko svaki žanr ima filmova i prikazati bar chart
# za prvih deset žanrova.
# ============================================================

# Šta se radi:
# split deli žanrove, explode pravi poseban red za svaki žanr,
# value_counts broji pojavljivanja, head(10) uzima prvih 10.

zanrovi = df.copy()
zanrovi["genres"] = zanrovi["genres"].str.split(",")
zanrovi = zanrovi.explode("genres")
zanrovi["genres"] = zanrovi["genres"].str.strip()

broj_po_zanru = zanrovi["genres"].value_counts()
top10_zanrova = broj_po_zanru.head(10)

print("\n--- ZADATAK 5: BROJ FILMOVA PO ŽANRU ---")
print(broj_po_zanru)

fig_zanrovi = px.bar(
    x=top10_zanrova.index,
    y=top10_zanrova.values,
    labels={"x": "Žanr", "y": "Broj filmova"},
    title="Top 10 žanrova"
)

# fig_zanrovi.show()


# ============================================================
# ZADATAK 5 — VARIJANTA 1A
# Izračunati koliko svaki režiser ima filmova i prikazati bar chart

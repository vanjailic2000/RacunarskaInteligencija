# ============================================================
# ZADATAK 9
# Scatter plot: zavisnost godine od žanra.
# Ako film ima više žanrova, tačka za svaki žanr.
# ============================================================

filmovi_za_scatter = df.copy()
filmovi_za_scatter["genres"] = filmovi_za_scatter["genres"].str.split(",")
filmovi_za_scatter = filmovi_za_scatter.explode("genres")
filmovi_za_scatter["genres"] = filmovi_za_scatter["genres"].str.strip()

fig_scatter = px.scatter(
    filmovi_za_scatter,
    x="genres",
    y="year_norm",
    hover_name="title",
    title="Zavisnost godine od žanra"
)


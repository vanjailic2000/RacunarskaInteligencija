#print(df[df["director"] != df["writers"]])---prikazuje podatke o filmovima jer stampa ceo red
#a prva pokazuje samo nazive filmova



# ==========================
# ZADATAK 9
# Scatter plot godina - žanr
# ==========================

df2 = df.copy()

df2["genres"] = df2["genres"].str.split(",")

df2 = df2.explode("genres")

fig = px.scatter(
    df2,
    x="genres",
    y="year_norm"
)

fig.show()
